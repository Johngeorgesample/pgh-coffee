MAPBOX_ACCESS_TOKEN=0000000

## Grafana Mimir (server-side metrics)
MIMIR_URL=https://prometheus-prod-xx-prod-us-east-2.grafana.net
MIMIR_USER=your-mimir-user-id
MIMIR_PASSWORD=your-mimir-api-token

## Grafana Loki (server-side logging)
LOKI_URL=https://logs-prod-036.grafana.net
LOKI_USER=your-loki-user-id
LOKI_PASSWORD=your-loki-api-token

## Grafana Pyroscope (server-side continuous profiling)
PYROSCOPE_URL=https://profiles-prod-xxx.grafana.net
PYROSCOPE_USER=your-pyroscope-user-id
PYROSCOPE_PASSWORD=your-pyroscope-api-token
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-oauth-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret